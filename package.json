{
  "name": "delta-move",
  "version": "0.0.1-debug",
  "description": "Lightweight delta-based animation library with easing effects.",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist/main.js",
    "dist/main.js.map",
    "dist/main.d.ts",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:types": "tsc -p src/tsconfig.json --emitDeclarationOnly",
    "build:web": "webpack",
    "build:web:dev": "NODE_ENV=development webpack",
    "build": "npm run clean && npm run build:types && npm run build:web",
    "build:dev": "npm run clean && npm run build:types && npm run build:web:dev",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ECRomaneli/delta-move.git"
  },
  "keywords": [
    "delta-move",
    "animation",
    "easing",
    "tweening",
    "tween",
    "tween-fn",
    "motion",
    "delta",
    "animate"
  ],
  "author": "ECRomaneli",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ECRomaneli/delta-move/issues"
  },
  "homepage": "https://github.com/ECRomaneli/delta-move#readme",
  "engines": {
    "node": ">=12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}